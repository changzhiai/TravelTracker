# --- Email Configuration ---
# DO NOT PUT REAL PASSWORDS HERE. This file is public.
# Copy this file to .env or server/.env and fill in real values on your server/local machine.

# Option 1: Outlook / Hotmail / Live
# EMAIL_SERVICE=hotmail
# EMAIL_USER=your-email@outlook.com
# EMAIL_PASS=your-app-password

# Option 2: Gmail
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password