{
  "name": "travel-tracker",
  "private": true,
  "version": "0.0.0",
  "author": "Changzhi Ai",
  "description": "A travel tracking application",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "cd server && node server.js",
    "server": "cd server && node server.js",
    "build": "tsc -b && vite build",
