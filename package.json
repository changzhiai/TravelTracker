    "@capacitor/status-bar": "^8.0.0",
    "@capgo/capacitor-social-login": "^8.3.9",
    "@react-oauth/google": "^0.13.4",
    "@turf/turf": "^7.3.0",
    "d3": "^7.9.0",
    "d3-geo-projection": "^4.0.0",
    "jspdf": "^4.0.0",
    "jszip": "^3.10.1",
    "react": "^19.2.0",
    "react-apple-signin-auth": "^1.1.2",
